# Copier en .env.local (NE JAMAIS commiter) ou configurer dans Vercel.

# Cle API Anthropic - obligatoire
# Recuperable sur https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxx

# Modele Claude a utiliser - optionnel, defaut Haiku 4.5 (rapide + pas cher)
# Alternatives :
#   claude-haiku-4-5-20251001  (rapide, ~0.0003 USD par appel)
#   claude-sonnet-4-6          (plus precis, ~0.003 USD par appel)
#   claude-opus-4-6            (top qualite, ~0.015 USD par appel)
ANTHROPIC_MODEL=claude-haiku-4-5-20251001
